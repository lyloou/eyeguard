#!/bin/bash
# eyeguard вҖ” жҠӨзңјеҚ«еЈ«е‘Ҫд»ӨиЎҢе·Ҙе…·
# йҖҡиҝҮ Unix Domain Socket дёҺ EyeGuard App йҖҡдҝЎ

SOCK="/tmp/eyeguard.sock"
TIMEOUT=2

# в”Җв”Җ е·Ҙе…·еҮҪж•° в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

die() {
    echo "Error: $*" >&2
    exit 1
}

is_app_running() {
    pgrep -x "EyeGuard" > /dev/null 2>&1
}

# еҸ‘йҖҒе‘Ҫд»ӨеҲ° socketпјҢиҝ”еӣһеҺҹе§Ӣиҫ“еҮә
send() {
    local cmd="$1"
    if ! is_app_running; then
        echo "Error: EyeGuard жңӘиҝҗиЎҢгҖӮиҜ·е…ҲеҗҜеҠЁжҠӨзңјеҚ«еЈ« AppгҖӮ" >&2
        exit 1
    fi
    local out
    # дјҳе…Ҳз”Ё PythonпјҲи·Ёе№іеҸ°еҸҜйқ пјүпјҢе…¶ж¬Ў nc
    if command -v python3 > /dev/null 2>&1; then
        out=$(python3 -c "
import socket, sys
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout($TIMEOUT)
try:
    s.connect('$SOCK')
    s.sendall(b'$cmd\n')
    sys.stdout.write(s.recv(4096).decode())
finally:
    s.close()
" 2>/dev/null)
    else
        out=$(printf '%s\n' "$cmd" | nc -U -w "$TIMEOUT" "$SOCK" 2>/dev/null)
    fi
    echo "$out"
}

# JSON и§Јжһҗпјҡjq дјҳе…ҲпјҢPython ж¬Ўд№ӢпјҢPerl е…ңеә•
parse_json() {
    local key="$1"
    local json="$2"
    if command -v jq > /dev/null 2>&1; then
        echo "$json" | jq -r ".$key // empty" 2>/dev/null
    elif command -v python3 > /dev/null 2>&1; then
        python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('$key',''))" <<< "$json"
    elif command -v perl > /dev/null 2>&1; then
        echo "$json" | perl -MJSON -ne "print decode_json(\$_)->{$key}" 2>/dev/null
    else
        # зәҜ shell е…ңеә•пјҡз®ҖеҚ• KV жӯЈеҲҷ
        echo "$json" | tr ',' '\n' | grep "\"$key\"" | sed 's/.*"\('$key'\)": *"\([^"]*\)".*/\2/'
    fi
}

is_json() {
    local txt="$1"
    echo "$txt" | grep -q '^{'
}

# в”Җв”Җ её®еҠ© в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

usage() {
    cat << 'EOF'
eyeguard вҖ” жҠӨзңјеҚ«еЈ«е‘Ҫд»ӨиЎҢе·Ҙе…·

з”Ёжі•: eyeguard <command>

е‘Ҫд»Ө:
  status       жҹҘзңӢеҪ“еүҚзҠ¶жҖҒпјҲеҗ«еү©дҪҷж—¶й—ҙпјү
  start        ејҖе§Ӣе·ҘдҪң
  pause        жҡӮеҒң
  resume       з»§з»ӯпјҲд»ҺжҡӮеҒңжҒўеӨҚпјү
  reset        йҮҚзҪ®еҪ“еүҚи®Ўж—¶
  rest-now     з«ӢеҚіиҝӣе…Ҙдј‘жҒҜ
  skip         и·іиҝҮдј‘жҒҜпјҲйңҖеӨ„дәҺдј‘жҒҜдёӯпјү
  stats        д»Ҡж—Ҙз»ҹи®ЎпјҲе·ҘдҪң/дј‘жҒҜ/иҪ®ж¬Ў + иҝ‘7ж—ҘеҺҶеҸІпјү
  settings     жҹҘзңӢеҪ“еүҚй…ҚзҪ®
  set-style    и®ҫзҪ®зҠ¶жҖҒж Ҹж ·ејҸпјҲclassic/minimal/emoji/compact/bracket/star/dots/progressBarпјү
  set-theme    и®ҫзҪ®еӨ–и§Ӯдё»йўҳпјҲsystem/light/darkпјү
  launch       еҗҜеҠЁжҠӨзңјеҚ«еЈ« App
  quit         йҖҖеҮәжҠӨзңјеҚ«еЈ« App
  dim          жҡ—еұҸпјҲдә®еәҰ=0%пјү
  bright       дә®еұҸпјҲдә®еәҰ=80%пјү
  toggle       жҡӮеҒң/з»§з»ӯпјҲеҲҮжҚўпјү
  help         жҳҫзӨәеё®еҠ©

зӨәдҫӢ:
  eyeguard status       вҶ’ е·ҘдҪңдёӯ 29:55
  eyeguard stats        вҶ’ д»Ҡж—Ҙе®ҢжҲҗ 3 иҪ®пјҢдј‘жҒҜ 15 еҲҶй’ҹ
  eyeguard settings     вҶ’ жҳҫзӨәжүҖжңүй…ҚзҪ®йЎ№
EOF
}

# в”Җв”Җ е‘Ҫд»ӨеӨ„зҗҶ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

cmd_status() {
    local out=$(send "status")
    if is_json "$out"; then
        local state=$(parse_json "state" "$out")
        local remaining=$(parse_json "remaining" "$out")
        local enforce=$(parse_json "enforceRest" "$out")

        case "$state" in
            idle)    echo "з©әй—І" ;;
            working) echo "е·ҘдҪңдёӯ $(format_seconds "$remaining")" ;;
            paused)  echo "е·ІжҡӮеҒң $(format_seconds "$remaining")" ;;
            resting) echo "дј‘жҒҜдёӯ $(format_seconds "$remaining")" ;;
            *)       echo "$out" ;;
        esac
    else
        echo "$out"
    fi
}

cmd_stats() {
    local out=$(send "stats")
    if is_json "$out"; then
        local rounds=$(parse_json "rounds" "$out")
        local work_min=$(parse_json "workMinutes" "$out")
        local rest_min=$(parse_json "restMinutes" "$out")
        echo "д»Ҡж—Ҙпјҡе·ҘдҪң ${work_min:-0} еҲҶй’ҹпјҢдј‘жҒҜ ${rest_min:-0} еҲҶй’ҹпјҢе®ҢжҲҗ ${rounds:-0} иҪ®"
        if command -v python3 > /dev/null 2>&1; then
            python3 -c "
import json, sys
d = json.load(sys.stdin)
hist = d.get('history') or []
if not hist:
    sys.exit(0)
print('иҝ‘ 7 ж—Ҙпјҡ')
for row in hist:
    print('  {}  е·ҘдҪң {} еҲҶ  дј‘жҒҜ {} еҲҶ  {} иҪ®'.format(
        row.get('date', '?'),
        row.get('workMinutes', 0),
        row.get('restMinutes', 0),
        row.get('rounds', 0),
    ))
" <<< "$out"
        fi
    else
        echo "$out"
    fi
}

cmd_settings() {
    local out=$(send "settings")
    if is_json "$out"; then
        local work=$(parse_json "workDuration" "$out")
        local rest=$(parse_json "restDuration" "$out")
        local enforce=$(parse_json "enforceRest" "$out")
        local pause=$(parse_json "pauseOnLock" "$out")
        local notify_work=$(parse_json "notifyOnWorkEnd" "$out")
        local notify_rest=$(parse_json "notifyOnRestEnd" "$out")
        local sound=$(parse_json "soundEnabled" "$out")
        local login=$(parse_json "launchAtLogin" "$out")
        local theme=$(parse_json "themeMode" "$out")

        echo "е·ҘдҪңж—¶й•ҝ:   $((work / 60)) еҲҶй’ҹ"
        echo "дј‘жҒҜж—¶й•ҝ:   $((rest / 60)) еҲҶй’ҹ"
        echo "ејәеҲ¶дј‘жҒҜ:   $(fmt_bool "$enforce")"
        echo "й”ҒеұҸжҡӮеҒң:   $(fmt_bool "$pause")"
        echo "е·ҘдҪңйҖҡзҹҘ:   $(fmt_bool "$notify_work")"
        echo "дј‘жҒҜйҖҡзҹҘ:   $(fmt_bool "$notify_rest")"
        echo "йҹіж•ҲжҸҗзӨә:   $(fmt_bool "$sound")"
        echo "ејҖжңәеҗҜеҠЁ:   $(fmt_bool "$login")"
        echo "зҠ¶жҖҒж Ҹж ·ејҸ: $(parse_json "statusBarStyle" "$out")"
        echo "еӨ–и§Ӯдё»йўҳ:   $theme"
    else
        echo "$out"
    fi
}

cmd_help() {
    usage
}

cmd_set-style() {
    local style="${1:-}"
    [[ -z "$style" ]] && { echo "з”Ёжі•: eyeguard set-style <ж ·ејҸеҗҚ>"; echo "еҸҜз”Ё: classic minimal emoji compact bracket star"; return 1; }
    local out=$(send "set-style $style")
    if is_json "$out"; then
        local ok=$(parse_json "ok" "$out")
        if [[ "$ok" == "true" ]]; then
            echo "зҠ¶жҖҒж Ҹж ·ејҸе·ІеҲҮжҚўдёә: $(parse_json "statusBarStyle" "$out")"
        else
            echo "Error: $(parse_json "error" "$out")" >&2
            return 1
        fi
    else
        echo "$out"
    fi
}

cmd_set-theme() {
    local theme="${1:-}"
    [[ -z "$theme" ]] && { echo "з”Ёжі•: eyeguard set-theme <system|light|dark>"; return 1; }
    local out=$(send "set-theme $theme")
    if is_json "$out"; then
        local ok=$(parse_json "ok" "$out")
        if [[ "$ok" == "true" ]]; then
            echo "еӨ–и§Ӯдё»йўҳе·ІеҲҮжҚўдёә: $(parse_json "themeMode" "$out")"
        else
            echo "Error: $(parse_json "error" "$out")" >&2
            return 1
        fi
    else
        echo "$out"
    fi
}

# в”Җв”Җ иҫ…еҠ© в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

format_seconds() {
    local s=${1:-0}
    printf '%02d:%02d\n' $((s / 60)) $((s % 60))
}

fmt_bool() {
    case "$1" in
        true|1|yes)  echo "ејҖ" ;;
        false|0|no)   echo "е…і" ;;
        *)            echo "$1" ;;
    esac
}

# в”Җв”Җ дё»е…ҘеҸЈ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

CMD="${1:-help}"

case "$CMD" in
    status)     cmd_status ;;
    stats)      cmd_stats ;;
    settings)   cmd_settings ;;
    set-style)
        shift
        cmd_set-style "$@"
        ;;
    set-theme)
        shift
        cmd_set-theme "$@"
        ;;
    help|--help|-h)
        cmd_help ;;
    quit)
        send "quit"
        ;;
    launch)
        open -a "EyeGuard"
        ;;
    dim)
        send "dim"
        ;;
    bright)
        send "bright"
        ;;
    *)
        # start/pause/resume/reset/rest-now/skip/toggle вҶ’ зӣҙжҺҘйҖҸдј 
        if [[ "$CMD" =~ ^(start|pause|resume|reset|rest-now|skip|toggle)$ ]]; then
            send "$CMD"
        else
            echo "жңӘзҹҘе‘Ҫд»Ө: $CMD" >&2
            usage >&2
            exit 1
        fi
        ;;
esac
